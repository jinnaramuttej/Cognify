import { NextRequest, NextResponse } from 'next/server'
import { db } from '@/lib/db'

// GET /api/tests/items/stats - Get item statistics
export async function GET(request: NextRequest) {
  try {
    const { searchParams } = new URL(request.url)
    const subjectId = searchParams.get('subjectId')
    const chapterId = searchParams.get('chapterId')
    const minAttempts = parseInt(searchParams.get('minAttempts') || '10')
    const flagged = searchParams.get('flagged') === 'true'

    // Build where clause for questions
    const whereClause: Record<string, unknown> = {
      timesAttempted: { gte: minAttempts }
    }
    
    if (subjectId) whereClause.subjectId = subjectId
    if (chapterId) whereClause.chapterId = chapterId

    // Get questions with stats
    const questions = await db.question.findMany({
      where: whereClause,
      include: {
        subject: { select: { name: true, color: true } },
        chapter: { select: { name: true } },
        itemStats: true
      },
      orderBy: { timesAttempted: 'desc' },
      take: 100
    })

    // Transform to include calculated stats
    const itemsWithStats = questions.map(q => {
      const pValue = q.timesAttempted > 0 
        ? q.timesCorrect / q.timesAttempted 
        : 0
      
      const avgTime = q.avgTimeSpent || 0

      return {
        id: q.id,
        text: q.text.substring(0, 100) + (q.text.length > 100 ? '...' : ''),
        subject: q.subject.name,
        subjectColor: q.subject.color,
        chapter: q.chapter.name,
        difficulty: q.difficulty,
        itemStatus: q.itemStatus,
        cognitiveLevel: q.cognitiveLevel,
        isPYQ: q.isPYQ,
        pyqYear: q.pyqYear,
        timesAttempted: q.timesAttempted,
        timesCorrect: q.timesCorrect,
        pValue: Math.round(pValue * 100) / 100,
        avgTimeSeconds: avgTime,
        discriminationIndex: q.itemStats?.discriminationIndex || null,
        irtA: q.itemStats?.irtA || null,
        irtB: q.itemStats?.irtB || null,
        irtC: q.itemStats?.irtC || null,
        qualityScore: q.itemStats?.qualityScore || null,
        isFlagged: q.itemStats?.isFlagged || false,
        flagReason: q.itemStats?.flagReason || null
      }
    })

    // Filter by flagged status if requested
    const filteredItems = flagged 
      ? itemsWithStats.filter(item => item.isFlagged)
      : itemsWithStats

    return NextResponse.json({
      items: filteredItems,
      total: filteredItems.length,
      stats: {
        avgPValue: filteredItems.reduce((sum, item) => sum + item.pValue, 0) / (filteredItems.length || 1),
        avgDiscrimination: filteredItems.filter(i => i.discriminationIndex !== null)
          .reduce((sum, item) => sum + (item.discriminationIndex || 0), 0) / 
          (filteredItems.filter(i => i.discriminationIndex !== null).length || 1),
        flaggedCount: itemsWithStats.filter(item => item.isFlagged).length,
        calibratedCount: itemsWithStats.filter(item => item.irtA !== null).length
      }
    })
  } catch (error) {
    console.error('Error fetching item stats:', error)
    return NextResponse.json(
      { error: 'Failed to fetch item statistics' },
      { status: 500 }
    )
  }
}

// POST /api/tests/items/stats - Calibrate item statistics
export async function POST(request: NextRequest) {
  try {
    const body = await request.json()
    const { questionIds, action } = body

    if (action === 'calibrate') {
      // Calibrate IRT parameters for specified questions
      const results = []
      
      for (const questionId of questionIds || []) {
        const question = await db.question.findUnique({
          where: { id: questionId },
          include: {
            attemptAnswers: {
              include: {
                attempt: {
                  include: {
                    answers: true
                  }
                }
              }
            }
          }
        })

        if (!question) continue

        // Calculate CTT statistics
        const responses = question.attemptAnswers.map(a => a.isCorrect ? 1 : 0)
        const totalScores = question.attemptAnswers.map(a => 
          a.attempt.answers.reduce((sum: number, ans) => 
            sum + (ans.isCorrect ? 1 : 0), 0
          )
        )

        const n = responses.length
        if (n < 10) continue // Need minimum responses

        // P-value
        const pValue = responses.reduce((sum, r) => sum + r, 0) / n
        
        // Point-biserial correlation (simplified)
        const meanTotal = totalScores.reduce((sum, s) => sum + s, 0) / n
        const sdTotal = Math.sqrt(
          totalScores.reduce((sum, s) => sum + Math.pow(s - meanTotal, 2), 0) / n
        )
        const meanCorrect = totalScores.filter((_, i) => responses[i] === 1)
          .reduce((sum, s) => sum + s, 0) / (responses.filter(r => r === 1).length || 1)
        
        const discriminationIndex = sdTotal > 0 
          ? (meanCorrect - meanTotal) / sdTotal * Math.sqrt(pValue * (1 - pValue))
          : 0

        // Estimate IRT parameters
        const irtB = -Math.log((1 - pValue) / pValue) / 1.7 // Simplified b estimate
        const irtA = Math.max(0.5, Math.min(2.5, Math.abs(discriminationIndex) * 1.7))
        const irtC = 0.25 // Default guessing for 4-option MCQ

        // Quality score
        const qualityScore = calculateQualityScore(pValue, discriminationIndex, n)

        // Update or create item stats
        await db.itemStats.upsert({
          where: { questionId },
          create: {
            questionId,
            pValue,
            discriminationIndex,
            avgTimeSeconds: question.avgTimeSpent || 0,
            medianTimeSeconds: question.avgTimeSpent || 0,
            irtA,
            irtB,
            irtC,
            irtCalibratedAt: new Date(),
            irtCalibrationCount: 1,
            qualityScore,
            isFlagged: qualityScore < 0.3,
            flagReason: qualityScore < 0.3 ? 'Low quality score' : null
          },
          update: {
            pValue,
            discriminationIndex,
            irtA,
            irtB,
            irtC,
            irtCalibratedAt: new Date(),
            irtCalibrationCount: { increment: 1 },
            qualityScore,
            isFlagged: qualityScore < 0.3,
            flagReason: qualityScore < 0.3 ? 'Low quality score' : null
          }
        })

        results.push({ questionId, pValue, discriminationIndex, irtA, irtB, qualityScore })
      }

      return NextResponse.json({
        success: true,
        calibrated: results.length,
        results
      })
    }

    if (action === 'flag') {
      // Flag items for review
      const { questionId, reason } = body
      
      await db.itemStats.update({
        where: { questionId },
        data: {
          isFlagged: true,
          flagReason: reason || 'Flagged for review'
        }
      })

      return NextResponse.json({ success: true })
    }

    return NextResponse.json({ error: 'Invalid action' }, { status: 400 })
  } catch (error) {
    console.error('Error in item stats operation:', error)
    return NextResponse.json(
      { error: 'Failed to process item stats' },
      { status: 500 }
    )
  }
}

// Helper function to calculate quality score
function calculateQualityScore(pValue: number, discrimination: number, n: number): number {
  // P-value component (ideal range 0.3-0.7)
  const pValueScore = 1 - Math.abs(pValue - 0.5) * 2
  
  // Discrimination component (higher is better, > 0.3 is good)
  const discriminationScore = Math.min(1, Math.max(0, discrimination / 0.5))
  
  // Sample size component (more responses = more reliable)
  const sampleScore = Math.min(1, n / 100)
  
  // Weighted average
  return pValueScore * 0.3 + discriminationScore * 0.5 + sampleScore * 0.2
}
