import { NextResponse } from 'next/server'
import { db } from '@/lib/db'

export async function GET() {
  try {
    const attempts = await db.testAttempt.findMany({
      where: {
        userId: 'demo-user',
        status: { in: ['submitted', 'auto_submitted'] }
      },
      include: {
        test: {
          include: {
            subject: {
              select: { name: true }
            }
          }
        }
      },
      orderBy: { submittedAt: 'desc' },
      take: 20
    })

    const history = attempts.map((attempt) => ({
      id: attempt.id,
      testId: attempt.testId,
      testName: attempt.test.name,
      subject: attempt.test.subject?.name,
      score: attempt.score,
      totalMarks: attempt.totalMarks,
      percentage: attempt.percentage,
      accuracy: attempt.accuracy,
      timeSpent: attempt.timeSpent,
      status: attempt.status,
      startedAt: attempt.startedAt,
      submittedAt: attempt.submittedAt
    }))

    // Calculate stats
    const totalTests = attempts.length
    const averageScore = totalTests > 0
      ? Math.round(attempts.reduce((sum, a) => sum + a.percentage, 0) / totalTests)
      : 0
    const totalTime = attempts.reduce((sum, a) => sum + a.timeSpent, 0)
    
    // Calculate improvement
    let improvement = 0
    if (attempts.length >= 5) {
      const recent = attempts.slice(0, 5)
      const previous = attempts.slice(5, 10)
      if (previous.length > 0) {
        const recentAvg = recent.reduce((sum, a) => sum + a.percentage, 0) / recent.length
        const previousAvg = previous.reduce((sum, a) => sum + a.percentage, 0) / previous.length
        improvement = Math.round(recentAvg - previousAvg)
      }
    }

    return NextResponse.json({
      success: true,
      history,
      stats: {
        totalTests,
        averageScore,
        totalTime,
        improvement
      }
    })
  } catch (error) {
    console.error('Error fetching history:', error)
    return NextResponse.json(
      { success: false, error: 'Failed to fetch history' },
      { status: 500 }
    )
  }
}
