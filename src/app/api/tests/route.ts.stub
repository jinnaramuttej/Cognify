import { NextRequest, NextResponse } from 'next/server'
import { db } from '@/lib/db'

export async function GET(request: NextRequest) {
  try {
    const { searchParams } = new URL(request.url)
    const status = searchParams.get('status')
    const subjectId = searchParams.get('subjectId')
    const grade = searchParams.get('grade')

    const where: {
      isPublic: boolean
      status?: string
      subjectId?: string
      grade?: string
    } = { isPublic: true }
    
    if (status) where.status = status
    if (subjectId) where.subjectId = subjectId
    if (grade) where.grade = grade

    const tests = await db.test.findMany({
      where,
      orderBy: { createdAt: 'desc' },
      include: {
        subject: {
          select: { id: true, name: true, color: true }
        },
        _count: {
          select: { questions: true, attempts: true }
        }
      }
    })

    const formattedTests = tests.map((test) => ({
      id: test.id,
      name: test.name,
      description: test.description,
      testType: test.testType,
      subjectId: test.subjectId,
      subject: test.subject,
      grade: test.grade,
      targetExam: test.targetExam,
      timeLimit: test.timeLimit,
      difficulty: test.difficulty,
      totalMarks: test.totalMarks,
      questionCount: test._count.questions,
      chapters: JSON.parse(test.chapters),
      subjectDistribution: JSON.parse(test.subjectDistribution),
      status: test.status,
      endsAt: test.endsAt,
      isInstitutional: test.isInstitutional,
      createdAt: test.createdAt,
      attemptsCount: test._count.attempts
    }))

    return NextResponse.json({
      success: true,
      tests: formattedTests
    })
  } catch (error) {
    console.error('Error fetching tests:', error)
    return NextResponse.json(
      { success: false, error: 'Failed to fetch tests' },
      { status: 500 }
    )
  }
}
